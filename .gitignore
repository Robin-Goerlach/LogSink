# =============================================================================
# Environment / secrets
# =============================================================================
.env
.env.local
.env.*.local

# =============================================================================
# PHP
# =============================================================================
/vendor/
/composer.lock
/services/*/vendor/
/services/*/composer.lock

# =============================================================================
# Java / Maven
# =============================================================================
/clients/*/target/
*.class

# =============================================================================
# .NET / WPF, falls später ein WPF-Client hinzukommt
# =============================================================================
/clients/*/bin/
/clients/*/obj/
*.user
*.suo

# =============================================================================
# Logs / runtime files
# =============================================================================
*.log
/var/log/*
!/var/log/.gitkeep
/services/*/var/log/*
!/services/*/var/log/.gitkeep

# =============================================================================
# Test / coverage / build artifacts
# =============================================================================
/.phpunit.cache/
/coverage/
/build/
/tmp/
/cache/
/services/*/.phpunit.cache/
/services/*/tmp/
/services/*/cache/

# =============================================================================
# IDEs and editors
# =============================================================================
/.idea/
/.vscode/
*.iml
*.ipr
*.iws
*.swp
*.swo

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
.env.IONOS

# Editor swap/backup files
*.kate-swp
.*.kate-swp
*.swp
*.swo
*~

# Local runtime configuration
client-settings.json
client-settings.local.json

# Keep the documented example configuration in Git.
!client-settings.example.json
